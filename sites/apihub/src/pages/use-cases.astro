---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { GITHUB_URL, INSTALL_URL } from '../data/content';
import { withBase } from '../lib/paths';
const home = import.meta.env.BASE_URL;

const rawUseCases = await getCollection('use-cases');
const scenarios = rawUseCases
  .sort((a, b) => a.data.order - b.data.order)
  .map((e) => e.data);

const colorMap: Record<string, { badge: string; bg: string; border: string; step: string }> = {
  blue:   { badge: 'bg-blue-500/15 text-blue-400 border-blue-500/30',   bg: 'bg-blue-500/5',   border: 'border-blue-500/25',   step: 'bg-blue-500/15 text-blue-400' },
  violet: { badge: 'bg-violet-500/15 text-violet-400 border-violet-500/30', bg: 'bg-violet-500/5', border: 'border-violet-500/25', step: 'bg-violet-500/15 text-violet-400' },
  emerald:{ badge: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30', bg: 'bg-emerald-500/5', border: 'border-emerald-500/25', step: 'bg-emerald-500/15 text-emerald-400' },
  orange: { badge: 'bg-orange-500/15 text-orange-400 border-orange-500/30', bg: 'bg-orange-500/5', border: 'border-orange-500/25', step: 'bg-orange-500/15 text-orange-400' },
  cyan:   { badge: 'bg-cyan-500/15 text-cyan-400 border-cyan-500/30',   bg: 'bg-cyan-500/5',   border: 'border-cyan-500/25',   step: 'bg-cyan-500/15 text-cyan-400' },
  pink:   { badge: 'bg-pink-500/15 text-pink-400 border-pink-500/30',   bg: 'bg-pink-500/5',   border: 'border-pink-500/25',   step: 'bg-pink-500/15 text-pink-400' },
};
---

<Layout
  title="Use Cases — Qubership APIHUB"
  description="See how API developers, DevOps, governance teams, and AI developers use Qubership APIHUB in their day-to-day workflows."
>
  <!-- Page Hero -->
  <section class="relative pt-16 pb-12 px-6 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] rounded-full opacity-15"
        style="background: radial-gradient(ellipse at center, rgba(59,130,246,0.6) 0%, transparent 70%); filter: blur(50px);"></div>
    </div>
    <div class="relative max-w-3xl mx-auto text-center">
      <!-- Breadcrumb -->
      <nav class="flex items-center justify-center gap-2 mb-6 text-sm text-slate-500">
        <a href={home} class="hover:text-white transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
        <span class="text-slate-300">Use Cases</span>
      </nav>
      <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">Real-world workflows</p>
      <h1 class="text-4xl md:text-5xl font-black text-white mb-5">
        Who uses APIHUB<br />
        <span class="gradient-text">and how?</span>
      </h1>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        From API developers to AI engineers — see the concrete business scenarios where APIHUB eliminates friction, reduces risk, and accelerates delivery.
      </p>
    </div>
  </section>

  <!-- Scenarios grid -->
  <section class="pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {scenarios.map((s) => {
          const c = colorMap[s.color];
          return (
            <div class={`rounded-2xl border ${c.border} ${c.bg} p-7 flex flex-col`}>
              <!-- Persona badge -->
              <div class="flex items-center gap-2.5 mb-5">
                <span class="text-2xl">{s.icon}</span>
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full border ${c.badge}`}>{s.persona}</span>
              </div>
              <h3 class="text-lg font-bold text-white mb-4">{s.title}</h3>

              <!-- Flow steps -->
              <div class="flex flex-wrap items-center gap-1.5 mb-5">
                {s.steps.map((step, i) => (
                  <>
                    <span class={`text-xs font-medium px-2.5 py-1 rounded-lg ${c.step}`}>{step}</span>
                    {i < s.steps.length - 1 && (
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-slate-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                    )}
                  </>
                ))}
              </div>

              <!-- Value prop -->
              <div class="mt-auto pt-4 border-t border-white/5">
                <p class="text-sm text-slate-300 leading-relaxed font-medium">
                  <span class="text-slate-500 font-normal">Value: </span>{s.value}
                </p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- AI integration spotlight -->
  <section class="py-20 px-6 border-y border-slate-800/50" style="background: rgba(15,23,42,0.5);">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">MCP & AI Integration</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-5">
            Your API catalog,<br />
            <span class="gradient-text">inside the LLM</span>
          </h2>
          <p class="text-slate-400 leading-relaxed mb-6">
            APIHUB exposes an MCP (Model Context Protocol) server so AI agents and LLMs can query your API catalog in real time — no hallucination, no stale data.
          </p>
          <ul class="space-y-3">
            {[
              'Search all API operations, schemas, and packages by natural language',
              'Fetch spec details, breaking change diffs, and quality scores',
              'Generate integration code with accurate, live API context',
              'Available in Claude Desktop, VS Code Copilot, and any MCP client',
            ].map((item) => (
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-blue-500/15 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                </div>
                <span class="text-sm text-slate-300">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="relative">
          <img src={withBase('images/feature-ai-mcp.png')} alt="APIHUB MCP server connecting to AI agents and LLMs" class="rounded-2xl border border-slate-800 w-full" loading="lazy" />
          <div class="absolute -bottom-4 -right-4 bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 shadow-xl">
            <div class="flex items-center gap-2 text-sm">
              <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
              <span class="text-slate-300 font-medium">MCP Server active</span>
            </div>
            <p class="text-xs text-slate-500 mt-0.5">Connected to VS Code, Claude Desktop</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Page nav -->
  <nav class="py-10 px-6">
    <div class="max-w-5xl mx-auto flex items-center justify-between">
      <a href={home} class="flex items-center gap-2 text-sm text-slate-500 hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" /></svg>
        Back to Home
      </a>
      <a href={withBase('features/')} class="flex items-center gap-2 text-sm text-blue-400 hover:text-blue-300 transition-colors font-medium">
        Explore Features
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>
  </nav>
</Layout>
