---
import Layout from '../layouts/Layout.astro';
import {
  deployOptions,
  GITHUB_URL,
  INSTALL_URL,
  ADMIN_URL,
  WIKI_IMG_APPLICATIONS_ARCH,
} from '../data/content';
import { withBase } from '../lib/paths';
const home = import.meta.env.BASE_URL;

const services = [
  { name: 'apihub-backend', desc: 'Core REST API server (Go)', color: 'blue' },
  { name: 'apihub-ui', desc: 'React frontend SPA', color: 'violet' },
  { name: 'postgresql', desc: 'Relational database', color: 'indigo' },
  { name: 'minio', desc: 'S3-compatible object storage', color: 'cyan' },
  { name: 'keycloak', desc: 'Identity & SSO (optional)', color: 'orange' },
  { name: 'k8s-agent', desc: 'Kubernetes discovery agent', color: 'emerald' },
];

const colorMap: Record<string, string> = {
  blue:   'bg-blue-500/10 text-blue-400 border-blue-500/20',
  violet: 'bg-violet-500/10 text-violet-400 border-violet-500/20',
  indigo: 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20',
  cyan:   'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
  orange: 'bg-orange-500/10 text-orange-400 border-orange-500/20',
  emerald:'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
};
---

<Layout
  title="Deploy — Qubership APIHUB"
  description="Deploy Qubership APIHUB with Docker Compose, Helm/Kubernetes, or build from source. Architecture overview included."
>
  <!-- Page Hero -->
  <section class="relative pt-16 pb-12 px-6 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] rounded-full opacity-15"
        style="background: radial-gradient(ellipse at center, rgba(249,115,22,0.5) 0%, transparent 70%); filter: blur(50px);"></div>
    </div>
    <div class="relative max-w-3xl mx-auto text-center">
      <nav class="flex items-center justify-center gap-2 mb-6 text-sm text-slate-500">
        <a href={home} class="hover:text-white transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
        <span class="text-slate-300">Deploy</span>
      </nav>
      <p class="text-sm font-semibold text-orange-400 uppercase tracking-widest mb-3">Self-hosted, Apache 2.0</p>
      <h1 class="text-4xl md:text-5xl font-black text-white mb-5">
        Deploy anywhere,<br />
        <span style="background: linear-gradient(135deg, #fb923c 0%, #a78bfa 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">your way</span>
      </h1>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        From a laptop to a production Kubernetes cluster — APIHUB runs wherever you need it. No license fees, no vendor lock-in.
      </p>
    </div>
  </section>

  <!-- Deploy options -->
  <section class="pb-16 px-6">
    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-6">
      {deployOptions.map((opt) => (
        <div class="rounded-2xl border border-slate-800 bg-slate-900 p-7 flex flex-col">
          <div class={`w-14 h-14 rounded-xl flex items-center justify-center mb-5 ${
            opt.color === 'blue' ? 'bg-blue-500/15 text-blue-400' :
            opt.color === 'violet' ? 'bg-violet-500/15 text-violet-400' :
            'bg-indigo-500/15 text-indigo-400'
          }`} set:html={opt.icon} />
          <div class="flex items-center gap-2 mb-3">
            <h2 class="text-lg font-bold text-white">{opt.title}</h2>
            <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${
              opt.color === 'blue' ? 'bg-blue-500/15 text-blue-400' :
              opt.color === 'violet' ? 'bg-violet-500/15 text-violet-400' :
              'bg-indigo-500/15 text-indigo-400'
            }`}>{opt.badge}</span>
          </div>
          <p class="text-sm text-slate-400 leading-relaxed mb-6 flex-1">{opt.description}</p>
          <a href={opt.href} target="_blank" rel="noopener"
            class="flex items-center gap-2 text-sm font-medium text-blue-400 hover:text-blue-300 transition-colors group">
            {opt.cta}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Architecture diagram -->
  <section class="py-16 px-6 border-y border-slate-800/50" style="background: rgba(15,23,42,0.4);">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Architecture overview</h2>
        <p class="text-slate-400">Six services, cleanly separated. Deploy only what you need.</p>
      </div>
      <div class="rounded-2xl overflow-hidden border border-slate-800">
        <div class="px-4 py-2 bg-slate-900 border-b border-slate-800 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-blue-400"></span>
          <span class="text-xs text-slate-500">Overall Application Architecture</span>
        </div>
        <img
          src={WIKI_IMG_APPLICATIONS_ARCH}
          alt="APIHUB application architecture diagram"
          class="w-full h-auto block"
          loading="lazy"
          data-lightbox
        />
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Service components</h2>
        <p class="text-slate-400">Each service is independently deployable and horizontally scalable.</p>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        {services.map((s) => (
          <div class={`rounded-xl border ${colorMap[s.color]} p-5 flex items-start gap-4`}>
            <div class={`w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 ${colorMap[s.color]}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>
            </div>
            <div>
              <div class="font-mono text-sm font-semibold text-white mb-1">{s.name}</div>
              <div class="text-xs text-slate-500">{s.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick start -->
  <section class="pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="rounded-2xl border border-slate-800 bg-slate-900 overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-800 flex items-center gap-2">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
          </div>
          <span class="text-xs text-slate-500 ml-1">Quick start with Docker Compose</span>
        </div>
        <div class="p-6 space-y-3 font-mono text-sm">
          <div>
            <span class="text-slate-500"># Clone the repository</span>
            <div class="mt-1"><span class="text-blue-400">$</span> <span class="text-slate-200">git clone https://github.com/Netcracker/qubership-apihub.git</span></div>
          </div>
          <div>
            <span class="text-slate-500"># Navigate to docker-compose directory</span>
            <div class="mt-1"><span class="text-blue-400">$</span> <span class="text-slate-200">cd qubership-apihub/docker-compose</span></div>
          </div>
          <div>
            <span class="text-slate-500"># Start all services</span>
            <div class="mt-1"><span class="text-blue-400">$</span> <span class="text-slate-200">docker compose up -d</span></div>
          </div>
          <div class="pt-2 border-t border-slate-800">
            <span class="text-slate-500"># Open in browser</span>
            <div class="mt-1"><span class="text-emerald-400">→</span> <span class="text-slate-200">http://localhost:8080</span></div>
          </div>
        </div>
      </div>
      <div class="flex gap-4 mt-6 justify-center">
        <a href={INSTALL_URL} target="_blank" rel="noopener"
          class="btn-primary flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-semibold text-white">
          Full Installation Guide
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
        </a>
        <a href={ADMIN_URL} target="_blank" rel="noopener"
          class="btn-secondary flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-semibold text-white">
          Admin Guide
        </a>
      </div>
    </div>
  </section>

  <!-- Page nav -->
  <nav class="py-10 px-6 border-t border-slate-800/40">
    <div class="max-w-5xl mx-auto flex items-center justify-between">
      <a href={withBase('releases/')} class="flex items-center gap-2 text-sm text-slate-500 hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" /></svg>
        Releases
      </a>
      <a href={home} class="flex items-center gap-2 text-sm text-blue-400 hover:text-blue-300 transition-colors font-medium">
        Back to Home
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>
  </nav>
</Layout>
