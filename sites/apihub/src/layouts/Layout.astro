---
import { ViewTransitions } from 'astro:transitions';
import { NAV_LINKS, GITHUB_URL, INSTALL_URL, DOCS_URL, WIKI_URL, RELEASES_URL } from '../data/content';
import { withBase, NETCRACKER_PAGES_ROOT } from '../lib/paths';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Qubership APIHUB — Open Source API Management Platform',
  description = 'A single point of truth for API documentation. Discover, compare, validate, and govern your APIs across OpenAPI, GraphQL, and AsyncAPI.',
  ogImage = '/og-image.png',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const ogPath =
  ogImage.startsWith('http') ? '' : import.meta.env.BASE_URL.replace(/^\//, '') + ogImage.replace(/^\//, '');
const ogImageAbsolute = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogPath, Astro.site!).href;

const norm = (p: string) => p.replace(/\/+$/, '') || '/';
const currentPath = norm(Astro.url.pathname);
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ViewTransitions />
    <style is:global>
      :root { color-scheme: dark; }
      body {
        background-color: #050813;
        color: #f1f5f9;
        font-family: 'Inter', system-ui, sans-serif;
        overflow-x: hidden;
      }
      html { scroll-behavior: smooth; }
      ::selection { background: rgba(59,130,246,0.3); }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #050813; }
      ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: #334155; }

      .gradient-text {
        background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .gradient-text-warm {
        background: linear-gradient(135deg, #34d399 0%, #60a5fa 50%, #a78bfa 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .card-glow:hover {
        box-shadow: 0 0 0 1px rgba(59,130,246,0.4), 0 8px 32px rgba(59,130,246,0.08);
      }
      .card-glow-violet:hover {
        box-shadow: 0 0 0 1px rgba(124,58,237,0.4), 0 8px 32px rgba(124,58,237,0.08);
      }
      .btn-primary {
        background: linear-gradient(135deg, #3b82f6, #7c3aed);
        transition: all 0.2s ease;
      }
      .btn-primary:hover {
        opacity: 0.9;
        transform: translateY(-1px);
        box-shadow: 0 8px 24px rgba(59,130,246,0.35);
      }
      .btn-secondary {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.12);
        transition: all 0.2s ease;
      }
      .btn-secondary:hover {
        background: rgba(255,255,255,0.08);
        border-color: rgba(255,255,255,0.2);
        transform: translateY(-1px);
      }
      .feature-tab.active {
        background: rgba(59,130,246,0.12);
        border-color: rgba(59,130,246,0.5) !important;
        color: #60a5fa !important;
      }
      .feature-panel { display: none; }
      .feature-panel.active { display: flex; }

      /* ── Page transition animations ──────────────────────────────────────── */
      @keyframes page-slide-in {
        from { opacity: 0; transform: translateY(18px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes page-slide-out {
        from { opacity: 1; transform: translateY(0); }
        to   { opacity: 0; transform: translateY(-10px); }
      }

      /* Apply to the main content area view-transition */
      ::view-transition-new(page-content) {
        animation: 0.35s cubic-bezier(0.22, 1, 0.36, 1) page-slide-in;
      }
      ::view-transition-old(page-content) {
        animation: 0.2s ease-in page-slide-out;
      }

      /* Header stays completely still */
      ::view-transition-new(site-header),
      ::view-transition-old(site-header) {
        animation: none;
      }
      /* Footer stays completely still */
      ::view-transition-new(site-footer),
      ::view-transition-old(site-footer) {
        animation: none;
      }
    </style>
  </head>
  <body class="antialiased flex flex-col min-h-screen">

    <!-- ══ HEADER (persisted across all page transitions) ══════════════════ -->
    <header
      transition:persist
      transition:name="site-header"
      class="sticky top-0 z-50 border-b border-slate-800/60 backdrop-blur-xl"
      style="background: rgba(5,8,19,0.88);"
    >
      <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between gap-4">
        <div class="flex items-center gap-4 min-w-0">
          <a
            href={NETCRACKER_PAGES_ROOT}
            class="hidden sm:inline text-xs font-medium text-slate-500 hover:text-white whitespace-nowrap transition-colors"
          >
            All products
          </a>
          <!-- Logo -->
          <a href={base} class="flex items-center gap-3 flex-shrink-0 min-w-0">
            <img src={withBase('images/logo.png')} alt="APIHUB Logo" class="h-8 w-auto" />
            <span class="font-bold text-lg tracking-tight text-white truncate">
              Qubership <span class="gradient-text">APIHUB</span>
            </span>
          </a>
        </div>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-1">
          {NAV_LINKS.map((link) => {
            const hrefNorm = norm(link.href);
            const isActive = !link.external && (
              currentPath === hrefNorm ||
              (hrefNorm !== norm(base) && currentPath.startsWith(hrefNorm + '/'))
            );
            return (
              <a
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener' : undefined}
                class={`px-3 py-2 rounded-lg text-sm font-medium transition-all duration-150 ${
                  isActive
                    ? 'bg-blue-500/15 text-blue-400'
                    : 'text-slate-400 hover:text-white hover:bg-white/5'
                }`}
              >
                {link.label}
                {link.external && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="inline w-3 h-3 ml-0.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
                )}
              </a>
            );
          })}
          <a
            href={GITHUB_URL}
            target="_blank" rel="noopener"
            class="px-3 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-white/5 transition-all duration-150 flex items-center gap-1.5"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/></svg>
            GitHub
          </a>
        </div>

        <a
          href={INSTALL_URL}
          target="_blank" rel="noopener"
          class="btn-primary hidden md:flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold text-white flex-shrink-0"
        >
          Get Started
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-slate-400 hover:text-white hover:bg-white/5"
          aria-label="Menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
        </button>
      </nav>

      <!-- Mobile nav -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800/60 px-6 py-4 space-y-1">
        {NAV_LINKS.map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener' : undefined}
            class="block px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-white/5 transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a href={GITHUB_URL} target="_blank" rel="noopener" class="block px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-white/5">GitHub</a>
      </div>
    </header>

    <!-- ══ PAGE CONTENT (transitions on each navigation) ═══════════════════ -->
    <main
      class="flex-1"
      transition:name="page-content"
      transition:animate="none"
    >
      <slot />
    </main>

    <!-- ══ FOOTER (persisted across all page transitions) ══════════════════ -->
    <footer
      transition:persist
      transition:name="site-footer"
      class="border-t border-slate-800/60 py-14 px-6 mt-auto"
    >
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-4 gap-10 mb-10">
          <div class="md:col-span-1">
            <a href={base} class="flex items-center gap-3 mb-4">
              <img src={withBase('images/logo.png')} alt="" class="h-8 w-auto" />
              <span class="font-bold text-base text-white">Qubership APIHUB</span>
            </a>
            <p class="text-sm text-slate-500 leading-relaxed mb-5">
              Open source API management platform. Built by Netcracker.
            </p>
            <a href={GITHUB_URL} target="_blank" rel="noopener" class="text-slate-500 hover:text-white transition-colors inline-block">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/></svg>
            </a>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-white uppercase tracking-wider mb-4">Navigate</h4>
            <ul class="space-y-2.5">
              {[
                { label: 'Home', href: base },
                { label: 'Use Cases', href: withBase('use-cases/') },
                { label: 'Features', href: withBase('features/') },
                { label: 'Capabilities', href: withBase('capabilities/') },
                { label: 'Releases', href: withBase('releases/') },
                { label: 'Deploy', href: withBase('deploy/') },
              ].map((l) => (
                <li><a href={l.href} class="text-sm text-slate-500 hover:text-white transition-colors">{l.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-white uppercase tracking-wider mb-4">Resources</h4>
            <ul class="space-y-2.5">
              {[
                { label: 'Installation Guide', href: INSTALL_URL },
                { label: 'User Guide', href: DOCS_URL },
                { label: 'Admin Guide', href: 'https://github.com/Netcracker/qubership-apihub/blob/main/docs/admin-guide.md' },
                { label: 'Wiki', href: WIKI_URL },
                { label: 'Releases', href: RELEASES_URL },
              ].map((l) => (
                <li><a href={l.href} target="_blank" rel="noopener" class="text-sm text-slate-500 hover:text-white transition-colors">{l.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-white uppercase tracking-wider mb-4">Community</h4>
            <ul class="space-y-2.5">
              {[
                { label: 'GitHub Issues', href: GITHUB_URL + '/issues' },
                { label: 'Pull Requests', href: GITHUB_URL + '/pulls' },
                { label: 'Discussions', href: GITHUB_URL + '/discussions' },
                { label: 'Product hub', href: NETCRACKER_PAGES_ROOT },
                { label: 'Netcracker on GitHub', href: 'https://github.com/Netcracker' },
              ].map((l) => (
                <li><a href={l.href} target="_blank" rel="noopener" class="text-sm text-slate-500 hover:text-white transition-colors">{l.label}</a></li>
              ))}
            </ul>
          </div>
        </div>
        <div class="border-t border-slate-800/60 pt-6 flex flex-col md:flex-row items-center justify-between gap-3">
          <p class="text-xs text-slate-600">
            © 2026 Netcracker Technology. Licensed under <a href="https://www.apache.org/licenses/LICENSE-2.0" target="_blank" class="hover:text-slate-400 transition-colors">Apache 2.0</a>.
          </p>
          <p class="text-xs text-slate-700">Built with Astro</p>
        </div>
      </div>
    </footer>

    <!-- ══ LIGHTBOX ══════════════════════════════════════════════════════════ -->
    <div
      id="lightbox"
      class="fixed inset-0 z-[200] hidden items-center justify-center p-4 md:p-10"
      style="background: rgba(0,0,0,0.88); backdrop-filter: blur(6px);"
      role="dialog"
      aria-modal="true"
      aria-label="Image preview"
    >
      <!-- Close button -->
      <button
        id="lightbox-close"
        class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10"
        aria-label="Close"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
      <!-- Image wrapper -->
      <div class="relative max-w-full max-h-full flex items-center justify-center">
        <img
          id="lightbox-img"
          src=""
          alt=""
          class="max-w-[90vw] max-h-[88vh] rounded-xl shadow-2xl object-contain border border-white/10"
          style="transform: scale(0.95); transition: transform 0.25s cubic-bezier(0.22,1,0.36,1);"
        />
      </div>
      <!-- Caption -->
      <p id="lightbox-caption" class="absolute bottom-5 left-1/2 -translate-x-1/2 text-sm text-slate-400 text-center max-w-xl px-4"></p>
    </div>

    <style is:global>
      /* Lightbox open animation */
      #lightbox.lb-open { display: flex !important; animation: lb-in 0.2s ease; }
      #lightbox.lb-open #lightbox-img { transform: scale(1) !important; }
      @keyframes lb-in {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
      /* Mark lightbox-enabled images */
      [data-lightbox] {
        cursor: zoom-in;
        transition: opacity 0.15s ease;
      }
      [data-lightbox]:hover { opacity: 0.88; }
    </style>

    <script>
      function initPage() {
        // ── Mobile menu ──────────────────────────────────────────────────────
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

        // ── Lightbox ─────────────────────────────────────────────────────────
        const lb      = document.getElementById('lightbox') as HTMLElement | null;
        const lbImg   = document.getElementById('lightbox-img') as HTMLImageElement | null;
        const lbCap   = document.getElementById('lightbox-caption') as HTMLElement | null;
        const lbClose = document.getElementById('lightbox-close') as HTMLElement | null;

        function openLightbox(src: string, alt: string) {
          if (!lb || !lbImg) return;
          lbImg.src = src;
          lbImg.alt = alt;
          if (lbCap) lbCap.textContent = alt || '';
          lb.classList.add('lb-open');
          document.body.style.overflow = 'hidden';
        }
        function closeLightbox() {
          if (!lb) return;
          lb.classList.remove('lb-open');
          lb.style.display = '';
          document.body.style.overflow = '';
        }

        // Attach click handlers to all [data-lightbox] images
        document.querySelectorAll<HTMLImageElement>('[data-lightbox]').forEach((img) => {
          img.addEventListener('click', () => openLightbox(img.src, img.alt));
        });

        // Close on backdrop click
        lb?.addEventListener('click', (e) => {
          if (e.target === lb) closeLightbox();
        });
        // Close button
        lbClose?.addEventListener('click', closeLightbox);
        // Close on Escape
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeLightbox();
        });
      }

      document.addEventListener('astro:page-load', initPage);
    </script>
  </body>
</html>
