---
import Layout from '../layouts/Layout.astro';
import { productDomains, topicSearchUrl, GITHUB_ORG_URL } from '../data/products';
---

<Layout>
  <main>
    <section class="relative px-6 pt-16 pb-12 overflow-hidden">
      <div
        class="pointer-events-none absolute inset-0 opacity-90"
        style="background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(59,130,246,0.2), transparent);"
      >
      </div>
      <div class="relative max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">
          Netcracker <span class="gradient-text">Open Source</span>
        </h1>
        <p class="text-lg text-slate-400 leading-relaxed mb-8">
          Enterprise-grade cloud platforms, integration tooling, observability stack, API governance and platform
          engineering. Explore Qubership product domains below — each area links to repositories on GitHub; dedicated
          product landings are added over time.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a
            href={GITHUB_ORG_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-violet-600 hover:opacity-95 transition-opacity"
          >
            Browse organization
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
              ><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path></svg
            >
          </a>
        </div>
      </div>
    </section>

    <section class="px-6 pb-20">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-xl font-bold text-white mb-2 text-center md:text-left">Product domains</h2>
        <p class="text-slate-500 text-sm mb-10 text-center md:text-left max-w-2xl">
          Grouped like the org profile catalog. Topics help you find related repositories on GitHub.
        </p>
        <div class="grid md:grid-cols-2 gap-5">
          {
            productDomains.map((p) => (
              <article
                class:list={[
                  'rounded-2xl border p-6 flex flex-col transition-all duration-200',
                  p.status === 'live'
                    ? 'border-blue-500/40 bg-slate-900/80 hover:border-blue-400/60 hover:shadow-lg hover:shadow-blue-500/5'
                    : 'border-slate-800 bg-slate-900/50 hover:border-slate-700',
                ]}
              >
                <div class="flex items-start gap-3 mb-3">
                  <span class="text-2xl" aria-hidden="true">
                    {p.icon}
                  </span>
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                      <h3 class="text-lg font-semibold text-white">{p.title}</h3>
                      {p.status === 'live' ? (
                        <span class="text-[10px] uppercase tracking-wider font-semibold px-2 py-0.5 rounded-full bg-blue-500/20 text-blue-300 border border-blue-500/30">
                          Landing live
                        </span>
                      ) : (
                        <span class="text-[10px] uppercase tracking-wider font-semibold px-2 py-0.5 rounded-full bg-slate-700/80 text-slate-400 border border-slate-600">
                          Coming soon
                        </span>
                      )}
                    </div>
                    <p class="text-slate-400 text-sm leading-relaxed">{p.description}</p>
                    <p class="text-slate-600 text-xs mt-2 font-mono">Topics: {p.topicsNote}</p>
                  </div>
                </div>
                <div class="mt-auto pt-4 flex flex-wrap gap-2">
                  {p.landingHref ? (
                    <a
                      href={p.landingHref}
                      class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-white bg-blue-600/90 hover:bg-blue-500 transition-colors"
                    >
                      Open landing
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                      </svg>
                    </a>
                  ) : null}
                  <a
                    href={topicSearchUrl(p.githubTopic)}
                    target="_blank"
                    rel="noopener noreferrer"
                    class:list={[
                      'inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium transition-colors border',
                      p.status === 'live'
                        ? 'border-slate-600 text-slate-300 hover:bg-white/5'
                        : 'border-slate-600 text-slate-300 hover:bg-white/5',
                    ]}
                  >
                    Repositories on GitHub
                  </a>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
