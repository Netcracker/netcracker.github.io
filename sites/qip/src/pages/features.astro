---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { features } from '../data/content';
---

<Layout title="QIP Features — Visual Integration Development" description="Explore the QIP graph editor, mapping, service catalog, deployments, sessions, and VS Code extension.">
  <PageHero eyebrow="Features" title="Build the flow. Keep the context." description="QIP connects visual design, reusable system definitions, deployment state, and execution details instead of scattering them across tools." />
  <section class="px-6 pb-24">
    <div class="mx-auto max-w-7xl">
      <div class="mb-7 flex gap-2 overflow-x-auto pb-2" role="tablist" aria-label="QIP features">
        {features.map((feature, index) => <button type="button" class:list={['feature-tab whitespace-nowrap rounded-xl border px-4 py-2.5 text-sm font-semibold transition-colors', index === 0 ? 'active border-blue-400/50 bg-blue-500/15 text-blue-300' : 'border-slate-800 bg-slate-900 text-slate-400 hover:text-white']} role="tab" aria-selected={index === 0 ? 'true' : 'false'} aria-controls={`panel-${feature.id}`} id={`tab-${feature.id}`} data-feature={feature.id}>{feature.label}</button>)}
      </div>

      {features.map((feature, index) => (
        <article id={`panel-${feature.id}`} class:list={['feature-panel glass-card scroll-mt-28 overflow-hidden rounded-3xl', index !== 0 && 'hidden']} role="tabpanel" aria-labelledby={`tab-${feature.id}`} data-panel={feature.id}>
          <div class="grid lg:grid-cols-[.76fr_1.24fr]">
            <div class="flex flex-col justify-center p-8 md:p-11">
              <p class="mb-3 font-mono text-xs uppercase tracking-wider text-blue-400">{feature.label}</p>
              <h2 class="mb-5 text-3xl font-black text-white">{feature.title}</h2>
              <p class="mb-7 leading-relaxed text-slate-400">{feature.description}</p>
              <ul class="space-y-3">{feature.points.map((point) => <li class="flex gap-3 text-sm text-slate-300"><span class="mt-1.5 h-2 w-2 flex-none rounded-full bg-[#9fdfd2]"></span>{point}</li>)}</ul>
            </div>
            <div class="relative min-h-72 border-t border-slate-800 bg-[#090e18] p-4 lg:border-l lg:border-t-0">
              <img src={feature.image} alt={feature.alt} class="h-full min-h-72 w-full rounded-2xl border border-slate-700/70 object-cover object-center shadow-2xl" width="1600" height="900" loading={index === 0 ? 'eager' : 'lazy'} data-lightbox />
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script>
    function initFeatureTabs() {
      const tabs = [...document.querySelectorAll<HTMLButtonElement>('[data-feature]')];
      const panels = [...document.querySelectorAll<HTMLElement>('[data-panel]')];
      const activate = (tab: HTMLButtonElement) => {
        const id = tab.dataset.feature;
        tabs.forEach((candidate) => {
          const active = candidate === tab;
          candidate.classList.toggle('active', active);
          candidate.classList.toggle('border-blue-400/50', active);
          candidate.classList.toggle('bg-blue-500/15', active);
          candidate.classList.toggle('text-blue-300', active);
          candidate.classList.toggle('border-slate-800', !active);
          candidate.classList.toggle('bg-slate-900', !active);
          candidate.classList.toggle('text-slate-400', !active);
          candidate.setAttribute('aria-selected', String(active));
          candidate.tabIndex = active ? 0 : -1;
        });
        panels.forEach((panel) => panel.classList.toggle('hidden', panel.dataset.panel !== id));
      };
      tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => activate(tab));
        tab.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;
          event.preventDefault();
          const nextIndex = event.key === 'Home' ? 0 : event.key === 'End' ? tabs.length - 1 : event.key === 'ArrowRight' ? (index + 1) % tabs.length : (index - 1 + tabs.length) % tabs.length;
          tabs[nextIndex]?.focus();
          if (tabs[nextIndex]) activate(tabs[nextIndex]);
        });
      });
    }
    document.addEventListener('astro:page-load', initFeatureTabs);
  </script>
</Layout>
