---
import Layout from '../layouts/Layout.astro';
import { DOCS_URL, features, GITHUB_URL, pillars, proofPoints } from '../data/content';
import { withBase } from '../lib/paths';
---

<Layout>
  <section class="page-glow relative overflow-hidden px-6 pb-20 pt-16 md:pt-24">
    <div class="grid-surface pointer-events-none absolute inset-0 opacity-70"></div>
    <div class="relative mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-10">
      <div>
        <div class="mb-7 inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/10 px-3 py-1.5 text-xs font-semibold text-blue-300">
          <span class="h-2 w-2 rounded-full bg-[#9fdfd2]"></span>
          Open-source integration on Apache Camel
        </div>
        <h1 class="mb-6 text-5xl font-black leading-[1.04] tracking-tight text-white md:text-7xl">
          Build integrations.<br /><span class="gradient-text-qip">Not plumbing.</span>
        </h1>
        <p class="mb-9 max-w-xl text-lg leading-relaxed text-slate-400 md:text-xl">
          Design, transform, deploy, and observe Apache Camel flows in one visual low-code workspace.
        </p>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a href={GITHUB_URL} target="_blank" rel="noopener" class="btn-primary inline-flex items-center justify-center gap-2 rounded-xl px-7 py-3.5 text-sm font-bold text-white">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .7a11.5 11.5 0 0 0-3.64 22.42c.58.1.79-.25.79-.56v-2.2c-3.22.7-3.9-1.36-3.9-1.36-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.57-.29-5.27-1.28-5.27-5.69 0-1.26.45-2.28 1.18-3.09-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.16 1.18a10.9 10.9 0 0 1 5.75 0c2.2-1.49 3.16-1.18 3.16-1.18.62 1.59.23 2.76.11 3.05.73.81 1.18 1.83 1.18 3.09 0 4.42-2.7 5.39-5.28 5.68.42.36.78 1.07.78 2.16v3.21c0 .31.21.67.8.56A11.5 11.5 0 0 0 12 .7Z" /></svg>
            View on GitHub
          </a>
          <a href={DOCS_URL} target="_blank" rel="noopener" class="btn-secondary inline-flex items-center justify-center rounded-xl px-7 py-3.5 text-sm font-semibold text-white">Read the docs</a>
        </div>
      </div>

      <div class="relative lg:-mr-40">
        <div class="absolute -inset-10 rounded-full bg-blue-500/10 blur-3xl"></div>
        <div class="relative overflow-hidden rounded-2xl border border-blue-400/20 bg-[#0a101c] p-1.5 shadow-2xl shadow-blue-950/40">
          <div class="mb-1 flex items-center gap-1.5 px-2 py-1.5" aria-hidden="true"><span class="h-2 w-2 rounded-full bg-slate-600"></span><span class="h-2 w-2 rounded-full bg-slate-600"></span><span class="h-2 w-2 rounded-full bg-slate-600"></span></div>
          <img src={withBase('images/hero-graph.png')} alt="QIP visual graph editor showing an HTTP-triggered integration with mapping, a service call, conditional Kafka publishing, database storage, and response mapping" class="aspect-video w-full rounded-xl object-cover object-center" width="1672" height="941" loading="eager" fetchpriority="high" data-lightbox />
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-800/70 bg-slate-950/40 px-6 py-9">
    <div class="mx-auto grid max-w-6xl grid-cols-2 gap-7 lg:grid-cols-4">
      {proofPoints.map((point) => <div><p class="mb-1 text-base font-extrabold text-white md:text-lg">{point.value}</p><p class="text-xs leading-relaxed text-slate-500">{point.label}</p></div>)}
    </div>
  </section>

  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto mb-14 max-w-3xl text-center">
        <p class="mb-3 text-xs font-bold uppercase tracking-[0.2em] text-blue-400">Why Qubership QIP?</p>
        <h2 class="mb-5 text-4xl font-black tracking-tight text-white md:text-5xl">Keep the flow visible.<br /><span class="gradient-text">Keep Camel underneath.</span></h2>
        <p class="text-lg leading-relaxed text-slate-400">Give developers a focused integration experience while retaining a powerful, cloud-native runtime.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {pillars.map((pillar, index) => (
          <a href={pillar.href} class="glass-card group rounded-2xl p-8 transition-all duration-200 hover:-translate-y-1">
            <div class:list={['mb-7 flex h-12 w-12 items-center justify-center rounded-xl text-lg font-black text-slate-950', pillar.color === 'mint' ? 'bg-[#9fdfd2]' : pillar.color === 'yellow' ? 'bg-[#fff19a]' : 'bg-blue-300']}>{index + 1}</div>
            <h3 class="mb-3 text-xl font-bold text-white">{pillar.title}</h3>
            <p class="mb-5 text-sm leading-relaxed text-slate-400">{pillar.description}</p>
            <span class="text-xs font-semibold text-blue-400 transition-colors group-hover:text-blue-300">Explore capability →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-950/35 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12 flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div><p class="mb-3 text-xs font-bold uppercase tracking-[0.2em] text-blue-400">One workflow</p><h2 class="text-3xl font-black text-white md:text-4xl">From design to evidence</h2></div>
        <a href={withBase('features/')} class="text-sm font-semibold text-blue-400 hover:text-blue-300">Explore every feature →</a>
      </div>
      <div class="grid gap-5 md:grid-cols-3">
        {features.slice(0, 3).map((feature) => (
          <article class="glass-card rounded-2xl p-6">
            <p class="mb-3 font-mono text-xs text-blue-400">{feature.label}</p>
            <h3 class="mb-3 text-lg font-bold text-white">{feature.title}</h3>
            <p class="text-sm leading-relaxed text-slate-400">{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6 py-20">
    <div class="mx-auto max-w-4xl overflow-hidden rounded-3xl border border-blue-400/30 bg-gradient-to-br from-blue-500/15 via-slate-950 to-violet-500/10 p-10 text-center md:p-14">
      <h2 class="mb-4 text-3xl font-black text-white md:text-4xl">See how the platform is built</h2>
      <p class="mx-auto mb-8 max-w-xl text-slate-300">Explore the source, run the development stack, and shape the next generation of Qubership Integration Platform.</p>
      <a href={GITHUB_URL} target="_blank" rel="noopener" class="btn-primary inline-flex rounded-xl px-7 py-3.5 text-sm font-bold text-white">View on GitHub</a>
    </div>
  </section>
</Layout>
