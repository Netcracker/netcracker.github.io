---
import Layout from '../layouts/Layout.astro';
const home = import.meta.env.BASE_URL;
---
<Layout title="404 — Page Not Found | Qubership QIP">
  <section class="flex min-h-[70vh] items-center justify-center px-6 py-20 text-center">
    <div><p class="gradient-text mb-4 text-8xl font-black">404</p><h1 class="mb-3 text-2xl font-bold text-white">Page not found</h1><p class="mb-8 text-slate-400">This integration route does not exist or has moved.</p><a href={home} class="btn-primary inline-flex rounded-xl px-6 py-3 text-sm font-semibold text-white">Back to Home</a></div>
  </section>
</Layout>
